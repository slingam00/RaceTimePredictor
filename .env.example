# RunSignup OAuth2 (register at https://runsignup.com/Profile/OAuth2 → App Development)
RUNSIGNUP_CLIENT_ID=
RUNSIGNUP_CLIENT_SECRET=
# Must exactly match a redirect URI on your OAuth client
RUNSIGNUP_REDIRECT_URI=http://localhost:8765/callback

# Optional: affiliate/partner API keys (alternative to OAuth)
# RUNSIGNUP_API_KEY=
# RUNSIGNUP_API_SECRET=

# Optional: set directly instead of using data/runsignup_tokens.json
# RUNSIGNUP_ACCESS_TOKEN=
